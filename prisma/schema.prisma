generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ─────────────────────────────────────────

enum Division {
  RFEF2_GRUPO_II  // 2º RFEF - Grupo II
  RFEF3_GRUPO_IV  // 3º RFEF - Grupo IV
  HONOR_BIZKAIA   // División de Honor - Bizkaia
}

enum Posicion {
  PORTERO
  DEFENSA
  CENTROCAMPISTA
  DELANTERO
  UNKNOWN
}

enum EstadoOferta {
  ACTIVA
  VENDIDA
  CANCELADA
}

enum TipoAccionAdmin {
  CREAR_JUGADOR
  EDITAR_JUGADOR
  CREAR_FICHAJE
  CERRAR_FICHAJE
  EDITAR_ESTADISTICA
  ACTUALIZAR_CONFIG
  CREAR_JORNADA
  GENERAR_SNAPSHOT
  SIMULAR_JORNADA
  CALCULAR_PUNTUACIONES
}

enum AccionPuntuacion {
  CONVOCADO
  TITULAR
  MINUTOS_60
  GOL
  TARJETA_AMARILLA
  TARJETA_ROJA
  VICTORIA
  EMPATE
  DERROTA
}

enum ResultadoPartido {
  VICTORIA
  EMPATE
  DERROTA
}

// ─── USUARIO ───────────────────────────────────────

model Usuario {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  contrasena   String
  creadoEn     DateTime  @default(now())
  ultimoAcceso DateTime?

  esAdmin      Boolean       @default(false)
  activo       Boolean       @default(true)

  ligasCreadas    Liga[]          @relation("CreadorLiga")
  membresias      MiembroLiga[]
  accionesAdmin   HistorialAdmin[]
}

// ─── LIGA ──────────────────────────────────────────

model Liga {
  id                 String   @id @default(uuid())
  nombre             String
  creadorId          String
  division           Division
  publica            Boolean  @default(true)
  codigoInvitacion   String?  @unique
  maxEquipos         Int      @default(10)
  presupuestoInicial Int      @default(100)
  creadoEn           DateTime @default(now())

  creador          Usuario           @relation("CreadorLiga", fields: [creadorId], references: [id])
  miembros         MiembroLiga[]
  plantillaFantasy PlantillaFantasy[]
  ofertas          OfertaMercado[]
  transferencias   Transferencia[]
}

// ─── MIEMBRO LIGA (equipo dentro de una liga) ──────

model MiembroLiga {
  id                  String   @id @default(uuid())
  ligaId              String
  usuarioId           String
  presupuestoRestante Int      @default(100)
  puntuacion          Int      @default(0)
  formacion           String?
  capitanId           String?
  creadoEn            DateTime @default(now())

  liga             Liga              @relation(fields: [ligaId], references: [id])
  usuario          Usuario           @relation(fields: [usuarioId], references: [id])
  capitan          Jugador?          @relation("CapitanLiga", fields: [capitanId], references: [id])
  plantillaFantasy PlantillaFantasy[]
  titulares        TitularLiga[]
  pujas            Puja[]
  ofertasVenta     OfertaMercado[]   @relation("OfertaVendedor")
  compras          Transferencia[]      @relation("TransferenciaComprador")
  ventas           Transferencia[]      @relation("TransferenciaVendedor")
  snapshots        SnapshotAlineacion[]
  puntuaciones     PuntuacionJornada[]

  @@unique([ligaId, usuarioId])
}

// ─── EQUIPO REAL ───────────────────────────────────

model Equipo {
  id       String   @id @default(uuid())
  nombre   String
  division Division
  creadoEn DateTime @default(now())

  jugadores JugadorEquipo[]
}

// ─── JUGADOR ───────────────────────────────────────

model Jugador {
  id              String    @id @default(uuid())
  nombreCompleto  String
  nombre          String
  dorsal          Int?
  fechaNacimiento DateTime?
  edad            Int?
  posicion        Posicion
  valor           Int       @default(0)
  creadoEn        DateTime  @default(now())

  historialEquipos JugadorEquipo[]
  plantillaFantasy PlantillaFantasy[]
  ofertas          OfertaMercado[]
  transferencias   Transferencia[]
  titularEn        TitularLiga[]
  capitanDe        MiembroLiga[]      @relation("CapitanLiga")
}

// ─── JUGADOR EQUIPO (historial real) ───────────────

model JugadorEquipo {
  id        String    @id @default(uuid())
  jugadorId String
  equipoId  String
  desde     DateTime  @default(now())
  hasta     DateTime?
  activo    Boolean   @default(true)
  creadoEn  DateTime  @default(now())

  jugador      Jugador              @relation(fields: [jugadorId], references: [id])
  equipo       Equipo               @relation(fields: [equipoId], references: [id])
  snapshots    SnapshotAlineacion[]
  estadisticas EstadisticaJornada[]

  @@index([jugadorId])
  @@index([equipoId, activo])
}

// ─── PLANTILLA FANTASY (jugadores de un equipo fantasy) ──

model PlantillaFantasy {
  id            String   @id @default(uuid())
  ligaId        String
  miembroLigaId String
  jugadorId     String
  precioCompra  Int
  creadoEn      DateTime @default(now())

  liga        Liga        @relation(fields: [ligaId], references: [id])
  miembroLiga MiembroLiga @relation(fields: [miembroLigaId], references: [id])
  jugador     Jugador     @relation(fields: [jugadorId], references: [id])

  @@unique([ligaId, jugadorId])
}

// ─── TITULAR LIGA (11 inicial de cada equipo) ──────

model TitularLiga {
  id            String @id @default(uuid())
  miembroLigaId String
  jugadorId     String

  miembroLiga MiembroLiga @relation(fields: [miembroLigaId], references: [id])
  jugador     Jugador     @relation(fields: [jugadorId], references: [id])

  @@unique([miembroLigaId, jugadorId])
}

// ─── OFERTA MERCADO ────────────────────────────────

model OfertaMercado {
  id             String       @id @default(uuid())
  ligaId         String
  jugadorId      String
  vendedorId     String?
  precioMinimo   Int
  estado         EstadoOferta @default(ACTIVA)
  fechaCaducidad DateTime?
  creadoEn       DateTime     @default(now())

  liga          Liga           @relation(fields: [ligaId], references: [id])
  jugador       Jugador        @relation(fields: [jugadorId], references: [id])
  vendedor      MiembroLiga?   @relation("OfertaVendedor", fields: [vendedorId], references: [id])
  pujas         Puja[]
  transferencia Transferencia?
}

// ─── PUJA ──────────────────────────────────────────

model Puja {
  id              String   @id @default(uuid())
  ofertaMercadoId String
  miembroLigaId   String
  cantidad        Int
  creadoEn        DateTime @default(now())

  oferta      OfertaMercado @relation(fields: [ofertaMercadoId], references: [id])
  miembroLiga MiembroLiga   @relation(fields: [miembroLigaId], references: [id])

  @@unique([ofertaMercadoId, miembroLigaId])
}

// ─── HISTORIAL ADMIN ───────────────────────────────

model HistorialAdmin {
  id           String          @id @default(uuid())
  adminId      String
  accion       TipoAccionAdmin
  entidad      String
  entidadId    String
  datosAntes   Json?
  datosDespues Json
  creadoEn     DateTime        @default(now())

  admin Usuario @relation(fields: [adminId], references: [id])
}

// ─── JORNADA ───────────────────────────────────────

model Jornada {
  id          String   @id @default(uuid())
  division    Division
  numJornada  Int
  fechaCierre DateTime

  snapshots    SnapshotAlineacion[]
  estadisticas EstadisticaJornada[]
  puntuaciones PuntuacionJornada[]

  @@unique([division, numJornada])
}

// ─── SNAPSHOT ALINEACION (inmutable) ───────────────

model SnapshotAlineacion {
  id              String   @id @default(uuid())
  jornadaId       String
  miembroLigaId   String
  jugadorEquipoId String
  esCapitan       Boolean  @default(false)
  creadoEn        DateTime @default(now())

  jornada       Jornada       @relation(fields: [jornadaId], references: [id])
  miembroLiga   MiembroLiga   @relation(fields: [miembroLigaId], references: [id])
  jugadorEquipo JugadorEquipo @relation(fields: [jugadorEquipoId], references: [id])

  @@unique([jornadaId, miembroLigaId, jugadorEquipoId])
}

// ─── TRANSFERENCIA (historial) ─────────────────────

model Transferencia {
  id          String   @id @default(uuid())
  jugadorId   String
  ligaId      String
  vendedorId  String?
  compradorId String
  ofertaId    String?  @unique
  precio      Int
  fecha       DateTime @default(now())

  jugador   Jugador        @relation(fields: [jugadorId], references: [id])
  liga      Liga           @relation(fields: [ligaId], references: [id])
  vendedor  MiembroLiga?   @relation("TransferenciaVendedor", fields: [vendedorId], references: [id])
  comprador MiembroLiga    @relation("TransferenciaComprador", fields: [compradorId], references: [id])
  oferta    OfertaMercado? @relation(fields: [ofertaId], references: [id])
}

// ─── CONFIG PUNTUACION ─────────────────────────────

model ConfigPuntuacion {
  id          String           @id @default(uuid())
  posicion    Posicion?
  accion      AccionPuntuacion
  puntos      Int
  desde       DateTime
  hasta       DateTime?
  activo      Boolean          @default(true)
  descripcion String?
}

// ─── ESTADISTICA JORNADA ───────────────────────────

model EstadisticaJornada {
  id                String           @id @default(uuid())
  jornadaId         String
  jugadorEquipoId   String
  convocado         Boolean          @default(false)
  titular           Boolean          @default(false)
  minutosJugados    Int              @default(0)
  goles             Int              @default(0)
  tarjetasAmarillas Int              @default(0)
  tarjetaRoja       Boolean          @default(false)
  resultado         ResultadoPartido @default(DERROTA)
  puntosCalculados  Int              @default(0)
  desglose          Json?

  jornada       Jornada       @relation(fields: [jornadaId], references: [id])
  jugadorEquipo JugadorEquipo @relation(fields: [jugadorEquipoId], references: [id])

  @@unique([jornadaId, jugadorEquipoId])
}

// ─── PUNTUACION JORNADA (por usuario) ──────────────

model PuntuacionJornada {
  id            String @id @default(uuid())
  jornadaId     String
  miembroLigaId String
  puntos        Int

  jornada     Jornada     @relation(fields: [jornadaId], references: [id])
  miembroLiga MiembroLiga @relation(fields: [miembroLigaId], references: [id])

  @@unique([jornadaId, miembroLigaId])
}
